; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the properties are organized in sections here.

[application]

config/name="Coastal Witch Tarot"
config/description="A cozy game about a witch building a tarot reading business in an expensive coastal city."
run/main_scene="res://scenes/main_menu/main_menu.tscn"
config/features=PackedStringArray("4.2", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/systems/game_state.gd"
Calendar="*res://scripts/systems/calendar_system.gd"
DailyCardSystem="*res://scripts/systems/daily_card_system.gd"
TarotDeck="*res://scripts/systems/tarot_deck.gd"
SceneManager="*res://scripts/systems/scene_manager.gd"
CompactMirror="*res://scripts/systems/compact_mirror_stub.gd"
CroneslistTimer="*res://scripts/systems/croneslist_timer.gd"
AudioManager="*res://scripts/systems/audio_manager.gd"
PronounManager="*res://scripts/systems/pronoun_manager.gd"
CharacterCustomization="*res://scripts/systems/character_customization.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

